{

  "description": "Adds a google bang in the duckduckgo search",
  "manifest_version": 3,
  "name": "BangDD",
  "version": "0.3.0",
  "homepage_url": "https://github.com/ylogx/BangDD",
  "icons": {
    "48": "icons/border-48.png"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "{ccbdc4ea-5f5c-452c-9566-d86d080af958}",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },

  "content_scripts": [
    {
      "matches": ["*://*.duckduckgo.com/*"],
      "js": ["dist/bangdd.js"]
    }
  ]

}
